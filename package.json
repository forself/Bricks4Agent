{
  "name": "bricks4agent",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "node packages/javascript/browser/page-generator/examples/test-all.js",
    "test:generator": "node packages/javascript/browser/page-generator/examples/test-generator.js",
    "audit:ui-styles": "node tools/scripts/audit-ui-style-rules.mjs",
    "validate:backend-governance": "node tools/scripts/validate-dotnet-dependencies.mjs && node tools/scripts/validate-dotnet-api-usage.mjs",
    "validate:baseorm-sync": "node tools/scripts/validate-baseorm-sync.mjs",
    "validate:dotnet-api-usage": "node tools/scripts/validate-dotnet-api-usage.mjs",
    "validate:dotnet-deps": "node tools/scripts/validate-dotnet-dependencies.mjs",
    "validate:ui-library": "node tools/scripts/validate-ui-library.mjs",
    "validate:ui-library:browser": "node tools/scripts/validate-ui-library.mjs --browser --require-browser",
    "serve": "dotnet run --project tools/static-server/StaticServer.csproj -- ./tools/spa-generator/frontend 3080"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "puppeteer": "^24.36.0"
  }
}
