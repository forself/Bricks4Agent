{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=spa_app.db"
  },
  "Jwt": {
    "_comment": "生產環境務必透過環境變數設定 Jwt:Key，至少 32 字元",
    "Key": "",
    "Issuer": "SpaApi"
  },
  "Cors": {
    "_comment": "生產環境務必設定具體的允許來源",
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://your-production-domain.com"
    ]
  },
  "SeedData": {
    "_comment": "初始管理員帳號設定，首次啟動時建立，建議登入後立即更改密碼",
    "AdminEmail": "admin@example.com",
    "AdminPassword": "Admin@123",
    "AdminName": "Admin"
  }
}
