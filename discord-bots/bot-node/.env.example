# Copy to .env (gitignored) and fill in real values.
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Phase 3+: shared secret between bot and broker.
# Generate one randomly (e.g. `openssl rand -hex 24`) and set the SAME value
# in tools/.env.trading on the broker side as BOT_INTERNAL_TOKEN.
BOT_INTERNAL_TOKEN=replace_with_strong_random_string
