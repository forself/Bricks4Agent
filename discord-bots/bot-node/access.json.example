{
  "_comment": "Copy this file to access.json (gitignored) and fill in your real Discord IDs. Default deny — empty arrays mean bot ignores everyone.",

  "_layer1_explain": "頻道層：誰看得到 bot。DM 限 allowed_user_ids；頻道訊息只看 allowed_channel_ids / allowed_guild_ids、頻道內成員都能用。",
  "allowed_user_ids": [
    "YOUR_DISCORD_USER_ID"
  ],
  "allowed_channel_ids": [
    "ALLOWED_CHANNEL_ID"
  ],
  "allowed_guild_ids": [],

  "_layer2_explain": "工具層：誰能 call 敏感工具（trading.* / audit.*）。沒設此欄位 → fallback allowed_user_ids（單人模式）。設了就獨立、頻道內非 privileged 的人 LLM 會收到 access_denied、會被告知去聯絡 anthonylee 開帳號。",
  "privileged_user_ids": [
    "YOUR_DISCORD_USER_ID"
  ],
  "privileged_tool_prefixes": [
    "trading.",
    "audit."
  ]
}
