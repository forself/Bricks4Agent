# ============================================
# Bricks4Agent Trading Stack — 環境變數設定
# ============================================
# 複製此檔案並填入你的 key:
#   cp tools/.env.trading.example tools/.env.trading
#
# 啟動:
#   docker compose -f tools/compose.trading.yml --env-file tools/.env.trading up -d --build
#
# ⚠ 機密管理（#1 secrets management）：
# 直接把 API key 寫進此檔案 = 純文字儲存、容易被 docker inspect / cron job env dump
# 等管道意外洩漏。要更安全的話用 Docker secrets 模式：
#   1. 把每個機密的純文字內容寫進 tools/secrets/{name}.txt（已在 .gitignore）
#   2. 啟動時加 -f tools/compose.trading.secrets.yml overlay：
#        docker compose --env-file tools/.env.trading \
#          -f tools/compose.trading.yml \
#          -f tools/compose.trading.secrets.yml up -d
#   3. 此檔案的 ALPACA_API_KEY 等可留空——overlay 的 *_FILE 環境變數會覆蓋
#   broker 跟 trading-worker 啟動時都會 log「Secret loaded: ... source=file/env/missing」總覽

# ── Broker Secrets（必填，自行產生隨機值）────────────
BROKER_SCOPED_TOKEN_SECRET=change-me-to-a-32-byte-random-secret
BROKER_MASTER_KEY_BASE64=change-me-base64-master-key
BROKER_ECDH_PRIVATE_KEY_BASE64=change-me-base64-ecdh-key

# ── Alpaca（美股 Paper Trading）──────────────────────
ALPACA_ENABLED=true
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_API_SECRET=your-alpaca-api-secret
ALPACA_IS_PAPER=true

# ── Binance（加密貨幣 Testnet）───────────────────────
BINANCE_ENABLED=true
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret
BINANCE_IS_TESTNET=true

# ── Quote Worker 設定 ────────────────────────────────
QUOTE_FETCH_INTERVAL=5
QUOTE_CRYPTO_IDS=bitcoin,ethereum,solana,dogecoin
QUOTE_STOCK_SYMBOLS=AAPL,MSFT,TSLA,NVDA

# ── 風控參數 ─────────────────────────────────────────
RISK_MAX_POSITION=10000
RISK_MAX_PORTFOLIO_PCT=25
RISK_MAX_ORDER_SIZE=5000
RISK_MAX_DAILY_LOSS=1000
RISK_MAX_DRAWDOWN=10
RISK_MAX_DAILY_TRADES=20

# ── LLM（選填，啟用 LLM 策略引擎）───────────────────
LLM_ENABLED=false
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=your-google-api-key
LLM_MODEL=gemini-2.0-flash

# ── Discord 通知 Webhook（選填）─────────────────────
# 在 Discord 頻道「編輯頻道 → 整合 → Webhook → 新增」取得 URL 後填入
# 留空 = 通知服務 graceful disabled，broker 照常運作
DISCORD_WEBHOOK_URL=
