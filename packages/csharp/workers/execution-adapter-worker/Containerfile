# ── Build Stage ──
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build

WORKDIR /src
COPY . .
RUN dotnet publish packages/csharp/workers/execution-adapter-worker/ExecutionAdapterWorker.csproj \
    -c Release -o /app/publish /p:UseAppHost=false

# ── Runtime Stage ──
FROM mcr.microsoft.com/dotnet/sdk:8.0

# repo-adapter 需要 git；build-test-adapter 需要 dotnet（sdk image 已含）。
# 用 sdk image 以便 dotnet build/test；git 額外安裝。
RUN apt-get update \
    && apt-get install -y --no-install-recommends git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=build /app/publish .

RUN adduser --disabled-password --gecos "" --uid 10004 execadapter \
    && mkdir -p /workspace \
    && chown -R execadapter:execadapter /app /workspace

USER execadapter

# git 需要 identity 才能某些操作；apply 不需 commit，但設個安全預設
ENV GIT_AUTHOR_NAME=execadapter GIT_AUTHOR_EMAIL=execadapter@bricks4agent.local \
    GIT_COMMITTER_NAME=execadapter GIT_COMMITTER_EMAIL=execadapter@bricks4agent.local

# No port — worker connects outbound to broker:7000
VOLUME ["/workspace"]

ENTRYPOINT ["dotnet", "ExecutionAdapterWorker.dll"]
