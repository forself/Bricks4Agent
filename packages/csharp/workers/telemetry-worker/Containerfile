FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src
COPY . .
RUN dotnet publish packages/csharp/workers/telemetry-worker/TelemetryWorker.csproj \
    -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:8.0
WORKDIR /app
COPY --from=build /app/publish .

RUN adduser --disabled-password --gecos "" --uid 10011 telemetryworker \
    && mkdir -p /data \
    && chown -R telemetryworker:telemetryworker /app /data

USER telemetryworker

# 純唯讀 outbound 到 broker:7000(SDK)+ broker:5000(健康端點),無需 inbound port
ENTRYPOINT ["dotnet", "TelemetryWorker.dll"]
