                "label": { "type": "string" },
                "url": { "type": "string" },
                "source_url": { "type": "string" },
                "scope": { "type": "string" }
              }
            }
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label", "url", "source_url", "scope"],
              "properties": {
                "label": { "type": "string" },
                "url": { "type": "string" },
                "source_url": { "type": "string" },
                "scope": { "type": "string" }
