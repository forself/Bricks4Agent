{
  "Worker": {
    "WorkerId": "browser-worker-01",
    "Capabilities": [ "browser.read" ],
    "BrokerHost": "127.0.0.1",
    "BrokerPort": 7000,
    "HeartbeatIntervalSeconds": 5,
    "ReconnectIntervalSeconds": 5,
    "AutoReconnect": true,
    "Auth": {
      "WorkerType": "browser-worker",
      "KeyId": "REPLACE_WITH_BROWSER_WORKER_KEY_ID",
      "SharedSecret": "REPLACE_WITH_BROWSER_WORKER_SHARED_SECRET"
    }
  },
  "Browser": {
    "Headless": true,
    "DefaultTimeoutMs": 30000,
    "NavigationTimeoutMs": 30000,
    "MaxConcurrentPages": 3,
    "UserAgent": "Bricks4Agent-BrowserWorker/1.0",
    "MaxContentLength": 8000,
    "ScreenshotOnEvidence": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  }
}
