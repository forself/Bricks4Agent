FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build

WORKDIR /src
COPY . .
RUN dotnet publish packages/csharp/workers/strategy-worker/StrategyWorker.csproj \
    -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:8.0

WORKDIR /app
COPY --from=build /app/publish .

RUN adduser --disabled-password --gecos "" --uid 10006 strategyworker \
    && chown -R strategyworker:strategyworker /app

USER strategyworker

ENTRYPOINT ["dotnet", "StrategyWorker.dll"]
