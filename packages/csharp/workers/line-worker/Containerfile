# ── Build Stage ──
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build

WORKDIR /src
COPY . .
RUN dotnet publish packages/csharp/workers/line-worker/LineWorker.csproj \
    -c Release -o /app/publish /p:UseAppHost=false

# ── Runtime Stage ──
FROM mcr.microsoft.com/dotnet/aspnet:8.0

WORKDIR /app
COPY --from=build /app/publish .

RUN adduser --disabled-password --gecos "" --uid 10004 lineworker \
    && mkdir -p /app/audio_temp /app/pending_messages \
    && chown -R lineworker:lineworker /app

USER lineworker

# Webhook receiver port (LINE platform → this container)
EXPOSE 19090

ENTRYPOINT ["dotnet", "LineWorker.dll"]
