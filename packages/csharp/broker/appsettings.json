{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "Path": "broker.db"
  },
  "Broker": {
    "ScopedToken": {
      "Secret": "CHANGE_ME_IN_PRODUCTION_USE_256_BIT_KEY_MINIMUM",
      "Issuer": "broker-control-plane",
      "Audience": "broker-agents",
      "ExpirationMinutes": 15
    },
    "Encryption": {
      "MasterKeyBase64": "CHANGE_ME_IN_PRODUCTION_USE_AES256_KEY",
      "EcdhPrivateKeyBase64": ""
    }
  },
  "FunctionPool": {
    "Enabled": false,
    "StrictMode": false,
    "ListenPort": 7000,
    "BindAddress": "0.0.0.0",
    "DispatchTimeoutSeconds": 30,
    "MaxRetries": 2,
    "HeartbeatTimeoutSeconds": 30,
    "HealthCheckIntervalSeconds": 10,
    "MaxWorkers": 100
  },
  "Embedding": {
    "Enabled": true,
    "Provider": "ollama",
    "BaseUrl": "http://localhost:11434",
    "Model": "nomic-embed-text",
    "Dimension": 768,
    "TimeoutSeconds": 30,
    "AlternativeModels": []
  },
  "RagPipeline": {
    "OllamaBaseUrl": "http://localhost:11434",
    "QueryRewriteEnabled": true,
    "QueryRewriteModel": "glm-4.7-flash",
    "RerankEnabled": true,
    "RerankModel": "glm-4.7-flash",
    "FallbackModel": "glm-4.7-flash",
    "CacheEnabled": true,
    "CacheTtlSeconds": 600,
    "TimeoutSeconds": 60
  },
  "LineChatGateway": {
    "Enabled": true,
    "MaxConversationHistory": 20,
    "RagEnabled": true,
    "RagTopK": 3,
    "SystemPrompt": "\u4f60\u662f\u4e00\u500b\u900f\u904e LINE \u901a\u8a0a\u7684\u667a\u6167\u52a9\u7406\u3002\u8acb\u7528\u7e41\u9ad4\u4e2d\u6587\u56de\u7b54\uff0c\u8a9e\u6c23\u89aa\u5207\u7c21\u6f54\u3002\u4f60\u53ef\u4ee5\u5229\u7528\u5167\u5efa\u7684\u77e5\u8b58\u5eab\uff08RAG\uff09\u4f86\u56de\u7b54\u6cd5\u5f8b\u76f8\u95dc\u554f\u984c\u3002"
  },
  "HighLevelLlm": {
    "Enabled": true,
    "Provider": "ollama",
    "BaseUrl": "http://localhost:11434",
    "ApiKey": "",
    "ApiFormat": "chat",
    "DefaultModel": "glm-4.7-flash:latest",
    "AllowModelOverride": false,
    "SupportsToolCalling": false,
    "StreamingEnabled": false,
    "TimeoutSeconds": 120
  },
