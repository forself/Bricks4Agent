{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "Path": "broker.db"
  },
  "Broker": {
    "ScopedToken": {
      "Secret": "CHANGE_ME_IN_PRODUCTION_USE_256_BIT_KEY_MINIMUM",
      "Issuer": "broker-control-plane",
      "Audience": "broker-agents",
      "ExpirationMinutes": 15
    },
    "Encryption": {
      "MasterKeyBase64": "CHANGE_ME_IN_PRODUCTION_USE_AES256_KEY",
      "EcdhPrivateKeyBase64": ""
    }
  },
  "FunctionPool": {
    "Enabled": false,
    "StrictMode": false,
    "ListenPort": 7000,
    "BindAddress": "0.0.0.0",
    "DispatchTimeoutSeconds": 30,
    "MaxRetries": 2,
    "HeartbeatTimeoutSeconds": 30,
    "HealthCheckIntervalSeconds": 10,
    "MaxWorkers": 100
  }
}
