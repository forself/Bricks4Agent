    "TaskId": "task_dashboard",
    "TaskType": "admin",
    "AssignedRoleId": "role_admin"
  },
  "HighLevelCoordinator": {
    "AccessRoot": "%LOCALAPPDATA%\\Bricks4Agent\\managed-workspaces",
    "AnonymousRegistrationPolicy": "allow_all"
  },
  "HighLevelLlm": {
