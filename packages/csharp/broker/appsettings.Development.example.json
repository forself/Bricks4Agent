  "Broker": {
    "Encryption": {
      "EcdhPrivateKeyBase64": "REPLACE_WITH_DEVELOPMENT_ECDH_PRIVATE_KEY_BASE64",
      "MasterKeyBase64": "REPLACE_WITH_DEVELOPMENT_AES256_MASTER_KEY_BASE64"
    },
    "ScopedToken": {
      "Secret": "REPLACE_WITH_DEVELOPMENT_SCOPED_TOKEN_SECRET"
