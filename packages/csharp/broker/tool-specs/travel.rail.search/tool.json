{
  "tool_id": "travel.rail.search",
  "display_name": "台鐵時刻查詢",
  "summary": "透過 TDX 台鐵時刻表 API 查詢站間班次，不使用搜尋引擎或官網抓取作為備援來源。",
  "kind": "travel",
  "status": "active",
  "version": "2026-04-08",
  "tags": ["travel", "rail", "tra", "train", "tdx", "timetable", "high-level"],
  "capability_template": {
    "action_type": "read",
    "resource_type": "travel",
    "risk_level": "low",
    "approval_policy": "auto",
    "ttl_seconds": 900,
    "audit_level": "summary",
    "quota": { "max_calls": 20, "per_window_seconds": 3600 }
  },
  "capability_bindings": [
    {
      "capability_id": "travel.rail.search",
      "route": "travel_rail_search",
      "purpose": "Broker-mediated Taiwan Railways timetable lookup via TDX API."
    }
  ],
  "input_schema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "以自然語言提供起訖站與日期時間，例如：台北 台中 今天 18:00。"
      },
      "locale": {
        "type": "string",
        "default": "zh-TW"
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 5,
        "default": 5
      }
    },
    "required": ["query"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "mode": { "type": "string", "enum": ["rail"] },
      "query": { "type": "string" },
      "retrieved_at": { "type": "string", "format": "date-time" },
      "tdx": {
        "type": "object",
        "properties": {
          "source": { "type": "string" },
          "origin": { "type": "string" },
          "destination": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "time_filter": { "type": "string" },
          "train_count": { "type": "integer" },
          "trains": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "train_no": { "type": "string" },
                "train_type": { "type": "string" },
                "departure_time": { "type": "string" },
                "arrival_time": { "type": "string" }
              }
            }
          }
        }
      },
      "sources_used": { "type": "array", "items": { "type": "string" } }
    }
  },
  "source_policy": {
    "allowed_sources": ["tdx"],
    "required_source": "tdx"
  },
  "execution_rules": {
    "mediation_required": true,
    "requires_source_policy": true,
    "default_limit": 5,
    "tdx_only": true,
    "web_fallback_allowed": false
  },
  "response_contract": {
    "must_identify_sources": true,
    "must_identify_retrieval_time": true,
    "result_wording": "回傳 TDX 台鐵時刻表結果；若 TDX 無資料，必須明確標示為無可用結果，不得改用網站搜尋。"
  }
}
