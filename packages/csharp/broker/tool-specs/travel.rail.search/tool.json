{
  "tool_id": "travel.rail.search",
  "display_name": "台鐵時刻表查詢",
  "summary": "查詢台灣鐵路（TRA）今日時刻表。優先使用 TDX 運輸資料流通服務 API 取得結構化班次資料，無法取得時 fallback 至網頁搜尋。",
  "kind": "travel",
  "status": "active",
  "version": "2026-03-28",
  "tags": ["travel", "rail", "tra", "train", "tdx", "timetable", "high-level"],
  "capability_template": {
    "action_type": "read",
    "resource_type": "travel",
    "risk_level": "low",
    "approval_policy": "auto",
    "ttl_seconds": 900,
    "audit_level": "summary",
    "quota": { "max_calls": 20, "per_window_seconds": 3600 }
  },
  "capability_bindings": [
    {
      "capability_id": "travel.rail.search",
      "route": "travel_rail_search",
      "purpose": "Broker-mediated Taiwan Railways timetable lookup via TDX API."
    }
  ],
  "input_schema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "自然語言查詢字串，應包含起站與訖站，可選時間。系統會自動從中提取站名。支援的分隔方式：空格、到、至、去、→。範例：「台北 台中」「台北到高雄 18:00」「基隆至花蓮」。支援的站名包括：基隆、汐止、南港、松山、台北/臺北、萬華、板橋、樹林、桃園、中壢、新竹、竹南、苗栗、豐原、台中/臺中、彰化、員林、田中、斗六、嘉義、新營、台南/臺南、高雄、左營、新左營、鳳山、屏東、潮州、宜蘭、羅東、蘇澳、花蓮、台東/臺東、瑞芳、七堵、鶯歌、新烏日、大甲、沙鹿。"
      },
      "locale": {
        "type": "string",
        "description": "語系，預設 zh-TW",
        "default": "zh-TW"
      },
      "limit": {
        "type": "integer",
        "description": "fallback 搜尋結果數量上限（TDX 模式不適用）",
        "minimum": 1,
        "maximum": 5,
        "default": 5
      }
    },
    "required": ["query"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "mode": { "type": "string", "enum": ["rail"] },
      "query": { "type": "string" },
      "retrieved_at": { "type": "string", "format": "date-time" },
      "tdx": {
        "type": "object",
        "description": "TDX API 結構化結果（優先路徑成功時存在）",
        "properties": {
          "source": { "type": "string" },
          "origin": { "type": "string" },
          "destination": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "train_count": { "type": "integer" },
          "trains": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "train_no": { "type": "string" },
                "train_type": { "type": "string", "description": "車種：自強、莒光、區間等" },
                "departure_time": { "type": "string", "description": "HH:mm 格式" },
                "arrival_time": { "type": "string", "description": "HH:mm 格式" }
              }
            }
          }
        }
      },
      "results": {
        "type": "array",
        "description": "fallback 網頁搜尋結果（TDX 路徑失敗時使用）"
      },
      "sources_used": { "type": "array", "items": { "type": "string" } }
    }
  },
  "source_policy": {
    "allowed_sources": ["tdx", "duckduckgo", "railway.gov.tw"],
    "preferred_source": "tdx"
  },
  "execution_rules": {
    "mediation_required": true,
    "requires_source_policy": true,
    "default_limit": 5,
    "tdx_priority": true,
    "tdx_fallback_to_web_search": true
  },
  "response_contract": {
    "must_identify_sources": true,
    "must_identify_retrieval_time": true,
    "result_wording": "回傳台鐵時刻表結果。TDX 路徑成功時回傳結構化班次（車次、車種、發車時間、到達時間）；fallback 時回傳網頁搜尋候選結果。AI 代理合成回覆時應以結構化班次為主，用自然語言整理成用戶可讀的時刻表格式。"
  }
}
