{
  "tool_id": "browser.reference.anonymous.navigate",
  "display_name": "Browser Reference: Anonymous Navigate",
  "summary": "Reference spec for broker-governed anonymous read-only multi-step navigation with action-level gating.",
  "kind": "browser",
  "status": "active",
  "version": "2026-06-12",
  "tags": ["browser", "reference", "anonymous", "navigate", "governed"],
  "capability_template": {
    "action_type": "read",
    "resource_type": "browser",
    "risk_level": "low",
    "approval_policy": "auto",
    "ttl_seconds": 900,
    "audit_level": "summary",
    "quota": { "max_calls": 20, "per_window_seconds": 3600 }
  },
  "capability_bindings": [
    {
      "capability_id": "browser.navigate",
      "route": "browser_navigate",
      "purpose": "Broker-governed anonymous read-only navigation; action level enforced in the worker runtime."
    }
  ],
  "browser_profile": {
    "identity_mode": "anonymous",
    "credential_source": "none",
    "session_owner": "none",
    "allowed_actions": ["read", "navigate"],
    "confirmation_policy": "broker_policy"
  },
  "browser_session_policy": {
    "binding_mode": "ephemeral",
    "credential_binding": "none",
    "reuse_scope": "none",
    "lease_minutes": 15,
    "requires_consent_record": false,
    "requires_interactive_login": false
  },
  "browser_site_policy": {
    "site_binding_mode": "public_open",
    "allowed_site_classes": ["public_web"],
    "requires_registered_site_binding": false,
    "requires_exact_origin_match": false,
    "allows_cross_origin_navigation": true
  },
  "browser_action_policy": {
    "max_action_level": "navigate",
    "requires_human_confirmation_on": ["authenticate", "draft_action", "committed_action"],
    "allows_form_fill": false,
    "allows_submit": false,
    "allows_download": false,
    "allows_file_upload": false
  },
  "input_schema": {
    "type": "object",
    "properties": {
      "start_url": { "type": "string" },
      "intended_action_level": { "type": "string", "enum": ["read", "navigate"] },
      "max_steps": { "type": "integer" },
      "allowed_host_suffixes": { "type": "array", "items": { "type": "string" } }
    },
    "required": ["start_url"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "request_id": { "type": "string" },
      "outcome": { "type": "string", "enum": ["executed", "gated"] },
      "action_level_reached": { "type": "string" },
      "gate_decision": { "type": "string" },
      "steps": { "type": "array" }
    }
  },
  "source_policy": {
    "allowed_sources": ["public_web"]
  },
  "execution_rules": {
    "runtime_required": "browser_worker",
    "session_persistence": "ephemeral",
    "allow_authenticated_access": false,
    "enforces_max_action_level": true
  },
  "response_contract": {
    "must_identify_identity_mode": true,
    "must_identify_source_type": true,
    "must_report_action_level_reached": true,
    "must_report_gate_decision": true
  }
}
