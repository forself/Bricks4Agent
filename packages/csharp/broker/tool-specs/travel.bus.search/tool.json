{
  "tool_id": "travel.bus.search",
  "display_name": "Bus Search",
  "summary": "Find candidate bus schedules through broker-approved sources and return candidate departure times.",
  "kind": "travel",
  "status": "active",
  "version": "2026-03-22",
  "tags": ["travel", "bus", "schedule", "high-level"],
  "capability_template": {
    "action_type": "read",
    "resource_type": "travel",
    "risk_level": "low",
    "approval_policy": "auto",
    "ttl_seconds": 900,
    "audit_level": "summary",
    "quota": { "max_calls": 20, "per_window_seconds": 3600 }
  },
  "capability_bindings": [
    {
      "capability_id": "travel.bus.search",
      "route": "travel_bus_search",
      "purpose": "Broker-mediated bus lookup."
    }
  ],
  "input_schema": {
    "type": "object",
    "properties": {
      "query": { "type": "string" },
      "locale": { "type": "string" },
      "limit": { "type": "integer", "minimum": 1, "maximum": 5 }
    },
    "required": ["query"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "mode": { "type": "string" },
      "query": { "type": "string" },
      "retrieved_at": { "type": "string" },
      "results": { "type": "array" },
      "sources_used": { "type": "array", "items": { "type": "string" } }
    }
  },
  "source_policy": {
    "allowed_sources": ["duckduckgo", "public_transport_web"]
  },
  "execution_rules": {
    "mediation_required": true,
    "requires_source_policy": true,
    "default_limit": 5
  },
  "response_contract": {
    "must_identify_sources": true,
    "must_identify_retrieval_time": true,
    "result_wording": "Return candidate bus options with any detected departure times."
  }
}
