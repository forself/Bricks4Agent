{
  "tool_id": "travel.hsr.search",
  "display_name": "THSR Search",
  "summary": "Find candidate Taiwan High Speed Rail schedules through broker-approved THSR sources.",
  "kind": "travel",
  "status": "active",
  "version": "2026-03-23",
  "tags": ["travel", "hsr", "thsr", "high-speed-rail", "search", "high-level"],
  "capability_template": {
    "action_type": "read",
    "resource_type": "travel",
    "risk_level": "low",
    "approval_policy": "auto",
    "ttl_seconds": 900,
    "audit_level": "summary",
    "quota": { "max_calls": 20, "per_window_seconds": 3600 }
  },
  "capability_bindings": [
    {
      "capability_id": "travel.hsr.search",
      "route": "travel_hsr_search",
      "purpose": "Broker-mediated Taiwan High Speed Rail lookup."
    }
  ],
  "input_schema": {
    "type": "object",
    "properties": {
      "query": { "type": "string" },
      "locale": { "type": "string" },
      "limit": { "type": "integer", "minimum": 1, "maximum": 5 }
    },
    "required": ["query"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "mode": { "type": "string" },
      "query": { "type": "string" },
      "retrieved_at": { "type": "string" },
      "results": { "type": "array" },
      "sources_used": { "type": "array", "items": { "type": "string" } }
    }
  },
  "source_policy": {
    "allowed_sources": ["duckduckgo", "thsrc.com.tw"]
  },
  "execution_rules": {
    "mediation_required": true,
    "requires_source_policy": true,
    "default_limit": 5
  },
  "response_contract": {
    "must_identify_sources": true,
    "must_identify_retrieval_time": true,
    "result_wording": "Return candidate Taiwan High Speed Rail options with detected departure or arrival time candidates."
  }
}
