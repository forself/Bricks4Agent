<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Broker</RootNamespace>

    <Version>1.0.0</Version>
    <Description>中介核心 — ASP.NET Core 8 Minimal API Host（全 POST、E2E 加密）</Description>
    <Authors>Bricks4Agent</Authors>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\broker-core\BrokerCore.csproj" />
    <!-- Phase 3: 功能池 -->
    <ProjectReference Include="..\function-pool\FunctionPool.csproj" />
    <!-- 重用現有模組 -->
    <ProjectReference Include="..\security\RateLimiting\RateLimiting.csproj" />
    <ProjectReference Include="..\logging\BaseLogger\BaseLogger.csproj" />
    <ProjectReference Include="..\workers\site-crawler-worker\SiteCrawlerWorker.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Broker.Tests" />
    <InternalsVisibleTo Include="Integration.Tests" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="verify\**\*.cs" />
    <Content Remove="verify\**\*" />
    <EmbeddedResource Remove="verify\**\*" />
    <None Remove="verify\**\*" />
  </ItemGroup>

  <ItemGroup>
    <Content Update="tool-specs\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <None Update="tool-specs\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!--
    HighLevelSiteRebuildService 在 broker 程序內就地使用 site-crawler-worker 的
    SiteCrawlerService / DeterministicSiteExtractor,因此 broker ProjectReference 了
    該 worker。但 worker 的 appsettings.json 會隨之流入 broker 的 publish 輸出,與
    broker 自己的 appsettings.json 相對路徑相同,造成 NETSDK1152。
    broker 容器只需要 broker 自己的設定,故在 publish 計算後移除來自 worker 的重複設定檔。
  -->
  <Target Name="RemoveTransitiveWorkerSettingsFromPublish" AfterTargets="ComputeFilesToPublish">
    <ItemGroup>
      <ResolvedFileToPublish
        Remove="@(ResolvedFileToPublish)"
        Condition="'%(RelativePath)' == 'appsettings.json' and $([System.String]::Copy('%(ResolvedFileToPublish.FullPath)').Replace('\','/').Contains('/site-crawler-worker/'))" />
    </ItemGroup>
  </Target>

</Project>
